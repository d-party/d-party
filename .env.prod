# 本番環境固有の値。`-f docker-compose.yml -f docker-compose.prod.yml` を明示したときに適用。
# .env.global の後に読まれ、同名キーを上書きする。デプロイ前に実値へ書き換えること。

DEBUG = 0
MY_DOMAIN = d-party.net

# Let's Encrypt の失効通知送付先（init-letsencrypt.sh が参照）。
CERTBOT_EMAIL = admin@example.com

# フロントエンドのビルド時に焼き込むバックエンド接続先（HTTPS / WSS）。
# NEXT_PUBLIC_* は next build 時に静的に埋め込まれるため、変更時は再ビルドが必要。
# ※ build 引数は env_file を読めないため、docker-compose.prod.yml の build.args にも
#   同じ値を持たせている（このファイルが正となるよう両者を一致させること）。
NEXT_PUBLIC_BACKEND_HOST = d-party.net/
NEXT_PUBLIC_BACKEND_PROTOCOL = https://
NEXT_PUBLIC_WEBSOCKET_PROTOCOL = wss://
