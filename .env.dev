# 開発環境固有の値。`docker compose up`（docker-compose.override.yml を自動読込）で適用。
# .env.global の後に読まれ、同名キーを上書きする。

DEBUG = 1
MY_DOMAIN = localhost

# フロントエンド（next dev）が実行時に参照するバックエンド接続先。
# 既定は env.ts のフォールバックと同じ localhost / http / ws。
NEXT_PUBLIC_BACKEND_HOST = localhost/
NEXT_PUBLIC_BACKEND_PROTOCOL = http://
NEXT_PUBLIC_WEBSOCKET_PROTOCOL = ws://
