{
  "name": "d-party Dev Container",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends pkg-config graphviz && sudo apt-get clean && sudo rm -rf /var/lib/apt/lists/*",
  "postCreateCommand": "git submodule update --init --recursive && (cd backend && uv sync && pre-commit install --install-hooks)",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "26"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers-extra/features/act:1": {},
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/devcontainers/features/github-cli:1.1.0": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "installDockerBuildx": true,
      "installDockerComposeSwitch": true,
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers-extra/features/cloudflared:1": {},
    "ghcr.io/rio/features/k3d:1": {},
    "ghcr.io/devcontainers-extra/features/k6:1": {
      "version": "0.55.0"
    }
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.mypy-type-checker",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "tamasfe.even-better-toml",
        "anthropic.claude-code",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "Redis.redis-for-vscode",
        "lottiefiles.vscode-lottie"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "sqltools.connections": [
          {
            "name": "d-party (compose postgres)",
            "driver": "PostgreSQL",
            "server": "localhost",
            "port": 5432,
            "database": "d_party",
            "username": "d_party",
            "password": "password",
            "connectionTimeout": 30
          }
        ],
        "sqltools.autoOpenSession": false,
        "sqltools.useNodeRuntime": true,
        "chat.tools.terminal.autoApprove": {
          "uv": true,
          "python": true,
          "python3": true,
          "pip": true,
          "pytest": true,
          "black": true,
          "act": true,
          "k6": true,
          "helm": true,
          "kubectl": true,
          "k3d": true,
          "ls": true,
          "cat": true,
          "pwd": true,
          "echo": true,
          "head": true,
          "tail": true,
          "wc": true,
          "tree": true,
          "which": true,
          "find": true,
          "grep": true,
          "rg": true,
          "/^git (status|log|diff|branch|show|fetch|remote|submodule|rev-parse)\\b/": true,
          "/^docker(\\s+compose)?\\s+(ps|logs|images|version|config)\\b/": true,
          "rm": false,
          "rmdir": false,
          "mv": false,
          "sudo": false,
          "chmod": false,
          "chown": false,
          "kill": false,
          "killall": false,
          "curl": false,
          "wget": false,
          "/^git (push|reset|rebase|clean|checkout|restore|commit)\\b/": false,
          "/^docker(\\s+compose)?\\s+(down|rm|kill|stop|prune)\\b/": false,
          "/\\brm\\b/": false,
          "/>|>>/": false,
          "/&&|\\|\\||;/": false
        }
      }
    }
  },
  "forwardPorts": [
    80,
    443,
    3000,
    5050,
    5432,
    6379,
    8000,
    9090,
    9100
  ],
  "portsAttributes": {
    "80": {
      "label": "Nginx (App)",
      "onAutoForward": "silent"
    },
    "443": {
      "label": "Nginx (HTTPS)",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "Grafana (metrics profile)",
      "onAutoForward": "silent"
    },
    "5050": {
      "label": "cAdvisor (metrics profile)",
      "onAutoForward": "silent"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "8000": {
      "label": "Django",
      "onAutoForward": "silent"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "silent"
    },
    "9100": {
      "label": "node-exporter",
      "onAutoForward": "silent"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "silent"
  },
  "remoteUser": "vscode",
  "mounts": [
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.claude",
      "target": "/home/vscode/.claude",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh",
      "target": "/home/vscode/.config/gh",
      "type": "bind"
    }
  ]
}
